 document.getElementById("driverReport").innerHTML=`<h2>Raporum</h2><div class="grid"><div class="box blueText"><b>Gün</b><span>${b.shifts.length}</span></div><div class="box blueText"><b>KM</b><span>${b.km}</span></div><div class="box greenText"><b>Nakit</b><span>${money(b.cash)}</span></div><div class="box blueText"><b>POS/Visa</b><span>${money(b.card)}</span></div><div class="box greenText"><b>Toplam</b><span>${money(b.income)}</span></div><div class="box redText"><b>Nakit Bakiye</b><span>${money(b.balance)}</span></div></div>`;
